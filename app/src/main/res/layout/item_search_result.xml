<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground">

    <!-- Gambar Produk / Edukasi -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivSearchItem"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        app:shapeAppearanceOverlay="@style/RoundedCornersImage" />

    <!-- Info Teks -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSearchItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Nama Produk"
            android:textColor="@color/colorTextPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSearchItemSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Rp 25.000"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Label Tipe -->
    <TextView
        android:id="@+id/tvSearchItemType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_search_bar"
        android:backgroundTint="@color/colorButtonLight"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Produk"
        android:textColor="@color/colorPrimary"
        android:textSize="11sp"
        android:textStyle="bold" />

</LinearLayout>
